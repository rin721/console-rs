# Aoi[葵] 本地开发环境变量示例。生产环境必须使用强随机密钥，不要复用 dev 值。
CONSOLE_CONFIG=configs/console.example.yaml
# CONSOLE_SECRETS=configs/console.secrets.yaml
CONSOLE__APP__ENVIRONMENT=local
CONSOLE__SERVER__HOST=127.0.0.1
CONSOLE__SERVER__PORT=8080
CONSOLE__DATABASE__DRIVER=sqlite
CONSOLE__DATABASE__URL=sqlite://data/console.sqlite
CONSOLE__AUTH__SELF_SIGNUP_ENABLED=false
CONSOLE__AUTH__SESSION_SECRET=dev-session-secret-change-me-32-bytes
CONSOLE__AUTH__MFA_SECRET_KEY=dev-mfa-secret-change-me-32-bytes
CONSOLE__AUTH__MFA_RECOVERY_CODE_COUNT=8
CONSOLE__AUTH__REFRESH_TTL_SECONDS=604800
CONSOLE__AUTH__CSRF__ENABLED=false
CONSOLE__AUTH__CSRF__COOKIE_NAME=console_csrf
CONSOLE__AUTH__CSRF__HEADER_NAME=X-CSRF-Token
CONSOLE__AUTH__CSRF__PATH=/
CONSOLE__AUTH__CSRF__SAME_SITE=Lax
CONSOLE__AUTH__CSRF__SECURE=false
CONSOLE__AUTH__CSRF__TTL_SECONDS=86400
CONSOLE__NOTIFICATION__DRIVER=file
CONSOLE__NOTIFICATION__LOCAL_DIR=data/notifications
CONSOLE__NOTIFICATION__BATCH_SIZE=50
CONSOLE__NOTIFICATION__LOCK_TTL_SECONDS=300
CONSOLE__NOTIFICATION__MAX_ATTEMPTS=3
CONSOLE__NOTIFICATION__RETRY_BACKOFF_SECONDS=60
CONSOLE__NOTIFICATION__DELIVERY_SECRET_KEY=dev-notification-secret-change-me-32-bytes
# 生产环境将 driver 改为 smtp 或 queue，并通过 secrets 注入以下 SMTP/queue 配置。
CONSOLE__NOTIFICATION__QUEUE__DIR=data/notification-queue
CONSOLE__NOTIFICATION__QUEUE__SECRET_KEY=replace-with-random-notification-queue-secret-at-least-32-bytes
CONSOLE__NOTIFICATION__SMTP__HOST=
CONSOLE__NOTIFICATION__SMTP__PORT=587
CONSOLE__NOTIFICATION__SMTP__USERNAME=
CONSOLE__NOTIFICATION__SMTP__PASSWORD=
CONSOLE__NOTIFICATION__SMTP__FROM=
CONSOLE__NOTIFICATION__SMTP__TLS=start_tls
CONSOLE__SCHEDULER__ENABLED=false
CONSOLE__SCHEDULER__RUN_ON_START=false
CONSOLE__SCHEDULER__TRAFFIC_PROBE_INTERVAL_SECONDS=300
CONSOLE__WEBUI__ENABLED=true
CONSOLE__WEBUI__DIST_DIR=web/app/dist
CONSOLE__STORAGE__DRIVER=local
CONSOLE__STORAGE__LOCAL_DIR=data/media
CONSOLE__STORAGE__MAX_UPLOAD_BYTES=8388608
# 使用 S3/MinIO/R2 时把 driver 改为 s3；生产凭据请由 secrets/env 注入。
CONSOLE__STORAGE__S3__ENDPOINT=
CONSOLE__STORAGE__S3__BUCKET=
CONSOLE__STORAGE__S3__REGION=us-east-1
CONSOLE__STORAGE__S3__ACCESS_KEY_ID=
CONSOLE__STORAGE__S3__SECRET_ACCESS_KEY=
CONSOLE__STORAGE__S3__FORCE_PATH_STYLE=true
CONSOLE__STORAGE__S3__ALLOW_HTTP=false
CONSOLE__STORAGE__S3__PREFIX=media
CONSOLE__AUDIT__OPERATION_RECORD_RETENTION_DAYS=180
CONSOLE__AUDIT__OPERATION_RECORD_PRUNE_BATCH_SIZE=1000
CONSOLE__OBSERVABILITY__LEVEL=info
CONSOLE__OBSERVABILITY__FORMAT=console
# 可选：Prometheus scrape token 只保存哈希；用 CONSOLE_OBSERVABILITY_SCRAPE_TOKEN=<raw> cargo run -p app -- observability-token-hash 生成。
CONSOLE__OBSERVABILITY__PROMETHEUS_SCRAPE_TOKEN_HASH=
# 仅目标环境验收脚本读取原始 token，用于证明授权 scrape 可用；不要写入配置文件或报告。
# CONSOLE_ACCEPTANCE_METRICS_SCRAPE_TOKEN=

