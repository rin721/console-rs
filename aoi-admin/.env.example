# 环境变量配置示例
# 使用时可以复制为 .env 并填写实际值。.env 不应提交到 Git。
# 生产环境建议直接使用系统环境变量、CI/CD secrets 或密钥管理服务。
#
# 命名策略：
# - 应用配置优先使用 <APP_PREFIX>_APP_<MODULE>_<FIELD>。
# - 当前 AppPrefix=Rin，因此前缀为 RIN_APP，例如 RIN_APP_DB_HOST、RIN_APP_SERVER_PORT。
# - 未加前缀的 <MODULE>_<FIELD> 仍作为兼容 fallback。

# ==================== 部署脚本默认值 ====================
# 以下变量只作为 deploy.sh / Docker Compose 的默认值，不属于 Go 应用运行时配置。
# 命令行参数优先级更高，例如 --data-dir 会覆盖 HOST_DATA_DIR。
# DEPLOY_PATH=/opt/go-scaffold
# DEPLOY_IMAGE=go-scaffold:local
# GITHUB_PROXY_HOST=github-com-gh.helloworlds.eu.org
# APP_PORT=9999
# APP_CONTAINER_PORT=9999
# HOST_CONFIG_DIR=/opt/go-scaffold/configs
# HOST_DATA_DIR=/var/lib/go-scaffold
# HOST_LOGS_DIR=/var/log/go-scaffold

# ==================== 数据库配置 ====================
# 数据库驱动类型：postgres、mysql、sqlite
# RIN_APP_DB_DRIVER=sqlite

# 数据库主机地址；SQLite 可不设置
# RIN_APP_DB_HOST=localhost

# 数据库端口；PostgreSQL 默认 5432，MySQL 默认 3306
# RIN_APP_DB_PORT=5432

# 数据库用户名；SQLite 可不设置
# RIN_APP_DB_USER=postgres

# 数据库密码；生产环境必须通过环境变量或密钥管理服务设置
# RIN_APP_DB_PASSWORD=your-secure-password

# 数据库名称；SQLite 使用文件路径
# RIN_APP_DB_NAME=./data/app.db

# 最大打开连接数
# RIN_APP_DB_MAX_OPEN_CONNS=10

# 最大空闲连接数
# RIN_APP_DB_MAX_IDLE_CONNS=5

# ==================== Redis 配置 ====================
# 是否启用 Redis
# RIN_APP_REDIS_ENABLED=false

# Redis 主机地址
# RIN_APP_REDIS_HOST=localhost

# Redis 端口
# RIN_APP_REDIS_PORT=6379

# Redis 密码
# RIN_APP_REDIS_PASSWORD=

# Redis 数据库索引
# RIN_APP_REDIS_DB=0

# Redis 连接池大小
# RIN_APP_REDIS_POOL_SIZE=20

# Redis 最小空闲连接数
# RIN_APP_REDIS_MIN_IDLE_CONNS=10

# Redis 最大重试次数
# RIN_APP_REDIS_MAX_RETRIES=3

# Redis 连接超时时间，单位秒
# RIN_APP_REDIS_DIAL_TIMEOUT=5

# Redis 读取超时时间，单位秒
# RIN_APP_REDIS_READ_TIMEOUT=3

# Redis 写入超时时间，单位秒
# RIN_APP_REDIS_WRITE_TIMEOUT=3

# ==================== 服务配置 ====================
# HTTP 服务器地址
# RIN_APP_SERVER_HOST=0.0.0.0

# HTTP 服务器端口
# RIN_APP_SERVER_PORT=9999

# 服务运行模式：debug、release、test
# RIN_APP_SERVER_MODE=release

# HTTP 读取超时时间，单位秒
# RIN_APP_SERVER_READ_TIMEOUT=10

# HTTP 写入超时时间，单位秒
# RIN_APP_SERVER_WRITE_TIMEOUT=10

# HTTP 空闲连接超时时间，单位秒
# RIN_APP_SERVER_IDLE_TIMEOUT=60

# ==================== WebUI 配置 ====================
# 是否由 Go HTTP 服务托管统一 React WebUI
# RIN_APP_WEBUI_ENABLED=true

# WebUI 挂载路径；默认根路径托管统一 SPA，不能与 /api、/health、/ready 冲突
# RIN_APP_WEBUI_MOUNT_PATH=/

# React 静态构建产物目录，需先执行 pnpm --dir web/app build
# RIN_APP_WEBUI_DIST_DIR=./web/app/build/client

# WebUI 对外访问地址，用于生成邀请和密码重置链接
# RIN_APP_WEBUI_PUBLIC_BASE_URL=/

# React dev server 与 Go API 分端口运行时使用；同源静态托管时保持空值
# VITE_PUBLIC_API_BASE_URL=http://127.0.0.1:9999

# 版本管理使用数据库迁移 20260612000500_create_system_versions.sql 和 IAM version:* 权限。
# 它不需要额外环境变量。
# 媒体库使用数据库迁移 20260612000600_create_system_media.sql 和 IAM media:* 权限。
# 断点上传还需要 20260612000700_create_system_media_resumable_uploads.sql。
# 普通上传、断点上传、本地下载需要启用 Storage；只浏览记录或导入外链时可以不启用对象存储。

# ==================== RPC 配置 ====================
# 是否启用独立 JSON-RPC 入口
# RIN_APP_RPC_ENABLED=false

# RPC 服务器地址
# RIN_APP_RPC_HOST=127.0.0.1

# RPC 服务器端口
# RIN_APP_RPC_PORT=10099

# RPC 读取超时时间，单位秒
# RIN_APP_RPC_READ_TIMEOUT=10

# RPC 写入超时时间，单位秒
# RIN_APP_RPC_WRITE_TIMEOUT=10

# RPC 空闲连接超时时间，单位秒
# RIN_APP_RPC_IDLE_TIMEOUT=30

# ==================== 日志配置 ====================
# 日志级别：debug、info、warn、error
# RIN_APP_LOG_LEVEL=info

# 日志格式：json、console
# RIN_APP_LOG_FORMAT=console

# 控制台日志格式：json、console
# RIN_APP_LOG_CONSOLE_FORMAT=console

# 文件日志格式：json、console
# RIN_APP_LOG_FILE_FORMAT=json

# 日志输出：stdout、file、both
# RIN_APP_LOG_OUTPUT=stdout

# 日志文件路径
# RIN_APP_LOG_FILE_PATH=./logs/app.log

# 单个日志文件最大大小，单位 MB
# RIN_APP_LOG_MAX_SIZE=100

# 保留旧日志文件数量
# RIN_APP_LOG_MAX_BACKUPS=7

# 保留旧日志文件天数
# RIN_APP_LOG_MAX_AGE=30

# ==================== 国际化配置 ====================
# 默认语言
# RIN_APP_I18N_DEFAULT=zh-CN

# 支持的语言列表，逗号分隔
# RIN_APP_I18N_SUPPORTED=zh-CN,en-US

# 语言文件目录
# RIN_APP_I18N_MESSAGES_DIR=./configs/locales

# ==================== 执行器配置 ====================
# 是否启用执行器
# RIN_APP_EXECUTOR_ENABLED=true

# ==================== 文件服务配置 ====================
# 是否启用存储服务
# RIN_APP_STORAGE_ENABLED=true

# 文件系统类型：memory、basepath 等
# RIN_APP_STORAGE_FS_TYPE=basepath

# basepath 文件系统根目录；媒体库会写入该目录下的 media/YYYY/MM/...，断点上传临时分片会写入 media/chunks/...
# RIN_APP_STORAGE_BASE_PATH=./data

# 是否启用文件变更监听
# RIN_APP_STORAGE_ENABLE_WATCH=false

# 文件变更监听缓冲区大小
# RIN_APP_STORAGE_WATCH_BUFFER_SIZE=100

# ==================== IAM 配置 ====================
# 是否启用 IAM 模块
# RIN_APP_AUTH_ENABLED=true

# 是否允许公开自助注册并创建首个组织 owner
# RIN_APP_AUTH_SELF_SIGNUP_ENABLED=true

# JWT issuer
# RIN_APP_AUTH_ISSUER=go-scaffold

# JWT audience，逗号分隔
# RIN_APP_AUTH_AUDIENCE=go-scaffold-api

# JWT 签名密钥；生产环境必须使用 secrets 注入，长度至少 32 字节
# RIN_APP_AUTH_SIGNING_KEY=change-me-at-least-32-bytes-long

# Access token 有效期，单位秒
# RIN_APP_AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token 有效期，单位秒
# RIN_APP_AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

# Refresh token HMAC pepper；生产环境必须使用 secrets 注入
# 同时用于 IAM API Token hash；轮换会让既有 refresh token 和 API Token 失效
# RIN_APP_AUTH_REFRESH_TOKEN_PEPPER=change-me-refresh-pepper

# TOTP issuer
# RIN_APP_AUTH_MFA_ISSUER=go-scaffold

# MFA secret 加密密钥；生产环境必须使用 secrets 注入，长度至少 32 字节
# RIN_APP_AUTH_MFA_SECRET_KEY=change-me-mfa-secret-key-32-bytes

# 登录失败锁定策略
# RIN_APP_AUTH_LOGIN_MAX_FAILURES=5
# RIN_APP_AUTH_LOGIN_LOCK_MINUTES=15
# RIN_APP_AUTH_LOGIN_CAPTCHA_ENABLED=false
# RIN_APP_AUTH_CAPTCHA_TTL_SECONDS=120

# 邀请和重置密码 token 有效期，单位秒
# RIN_APP_AUTH_INVITATION_TTL_SECONDS=86400
# RIN_APP_AUTH_PASSWORD_RESET_TTL_SECONDS=1800

# 通知驱动；debug/noop/local 会在 API 响应返回调试 token/link，生产应使用 smtp 或外部系统接管
# RIN_APP_AUTH_NOTIFICATION_DRIVER=debug

# SMTP 通知驱动；当 RIN_APP_AUTH_NOTIFICATION_DRIVER=smtp 时启用
# RIN_APP_AUTH_SMTP_HOST=smtp.example.com
# RIN_APP_AUTH_SMTP_PORT=587
# RIN_APP_AUTH_SMTP_USERNAME=mailer@example.com
# RIN_APP_AUTH_SMTP_PASSWORD=change-me
# RIN_APP_AUTH_SMTP_FROM=no-reply@example.com
# RIN_APP_AUTH_SMTP_FROM_NAME=Aoi Admin
# RIN_APP_AUTH_SMTP_STARTTLS=true

# 密码策略
# RIN_APP_AUTH_PASSWORD_MIN_LENGTH=8
# RIN_APP_AUTH_PASSWORD_REQUIRE_LOWER=false
# RIN_APP_AUTH_PASSWORD_REQUIRE_UPPER=false
# RIN_APP_AUTH_PASSWORD_REQUIRE_NUMBER=false
# RIN_APP_AUTH_PASSWORD_REQUIRE_SYMBOL=false

# Casbin policy 重载间隔，单位秒
# RIN_APP_AUTH_CASBIN_RELOAD_INTERVAL_SECONDS=300

# ==================== 迁移配置 ====================
# 是否在应用启动时自动执行迁移；生产建议保持 false，通过 CLI 显式执行
# RIN_APP_MIGRATION_AUTO_APPLY=false

# goose 迁移目录
# RIN_APP_MIGRATION_DIR=./internal/migrations

# ==================== 插件配置 ====================
# 是否启用外部 sidecar 插件
# RIN_APP_PLUGINS_ENABLED=false

# 远程插件心跳超时，单位秒
# RIN_APP_PLUGINS_HEARTBEAT_TIMEOUT_SECONDS=30


# ==================== System 配置 ====================
# 启动时幂等补齐系统字典和参数默认数据；已有数据不会被覆盖
# RIN_APP_SYSTEM_SEED_DEFAULTS_ON_START=true

# ==================== CORS 配置 ====================
# 是否启用 CORS
# RIN_APP_CORS_ENABLED=true

# 允许的来源，逗号分隔
# RIN_APP_CORS_ALLOW_ORIGINS=*

# 允许的方法，逗号分隔
# RIN_APP_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# 允许的请求头，逗号分隔；IAM Bearer token 需要 Authorization
# RIN_APP_CORS_ALLOW_HEADERS=Origin,Content-Type,X-Request-ID,Authorization

# 暴露给浏览器的响应头，逗号分隔
# RIN_APP_CORS_EXPOSE_HEADERS=X-Request-ID

# 是否允许跨域携带凭证
# RIN_APP_CORS_ALLOW_CREDENTIALS=false

# 预检缓存时间，单位秒
# RIN_APP_CORS_MAX_AGE=3600
