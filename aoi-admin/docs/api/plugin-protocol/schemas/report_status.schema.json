{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.example.local/plugin-protocol/schemas/report_status.schema.json",
  "title": "ReportStatusRequest",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/request_meta" },
    {
      "type": "object",
      "required": ["plugin_id", "instance_id"],
      "properties": {
        "plugin_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "status": { "enum": ["online", "offline", "draining"] },
        "runtime_status": { "enum": ["ready", "busy", "degraded", "draining"] },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  ]
}
