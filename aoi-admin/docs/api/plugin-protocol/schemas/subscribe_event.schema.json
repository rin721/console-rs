{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.example.local/plugin-protocol/schemas/subscribe_event.schema.json",
  "title": "SubscribeEventRequest",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/request_meta" },
    {
      "type": "object",
      "required": ["plugin_id", "instance_id", "events"],
      "properties": {
        "plugin_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "events": { "type": "array", "items": { "type": "string" } },
        "filters": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  ]
}
