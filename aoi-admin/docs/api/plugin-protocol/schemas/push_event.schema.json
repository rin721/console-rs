{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoi.example.local/plugin-protocol/schemas/push_event.schema.json",
  "title": "PushEventRequest",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/request_meta" },
    {
      "type": "object",
      "required": ["event"],
      "properties": {
        "plugin_id": { "type": "string" },
        "instance_id": { "type": "string" },
        "event": { "type": "string" },
        "permission_context": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "payload": true
      }
    }
  ]
}
