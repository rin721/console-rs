{
  "name": "@aoi/web-app",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.22.0"
  },
  "scripts": {
    "build": "pnpm theme:generate && pnpm content:generate && react-router build && node ./scripts/verify-build-output.mjs",
    "content:generate": "node ./scripts/generate-blog-posts.mjs",
    "dev": "pnpm theme:generate && react-router dev --host 127.0.0.1 --port 3002",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:i18n": "node ./scripts/lint-i18n.mjs",
    "test": "pnpm theme:check && pnpm content:generate && vitest run",
    "test:e2e": "playwright test",
    "test:unit": "pnpm theme:check && pnpm content:generate && vitest run",
    "theme:check": "node ./scripts/generate-theme.mjs --check && node ./scripts/check-theme-surface.mjs",
    "theme:generate": "node ./scripts/generate-theme.mjs",
    "typecheck": "pnpm theme:check && pnpm content:generate && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@react-router/node": "^8.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.0.0",
    "echarts": "6.1.0",
    "gray-matter": "^4.0.3",
    "i18next": "^25.0.0",
    "isbot": "^5",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-i18next": "^16.0.0",
    "react-markdown": "^10.0.0",
    "react-router": "^8.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@react-router/dev": "^8.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
